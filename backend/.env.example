# backend/.env  — NEVER commit this file. Add it to .gitignore.

APP_NAME="ANPR Parking Gate — ITB Jatinangor"
APP_VERSION="1.0.0"
DEBUG=true

# Generate key with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="REPLACE_WITH_32_BYTE_HEX_SECRET"
JWT_ALGORITHM="HS256"

# Generate key with: python -c "import secrets; print(secrets.token_hex(32))"
ANPR_KEY="REPLACE_WITH_32_BYTE_HEX_SECRET"

# Database & Cache (Docker akan menimpa ini secara otomatis, tapi baik jika disiapkan)
DATABASE_URL="postgresql+asyncpg://postgres:postgrespassword@localhost:5432/anpr_db"
REDIS_URL="redis://localhost:6379/0"
REDIS_COOLDOWN_TTL=10
REDIS_SESSION_TTL=86400

# MQTT Broker (Docker akan menimpa ini secara otomatis, tapi baik jika disiapkan)
MQTT_BROKER_URL="localhost"
MQTT_BROKER_PORT=1883
MQTT_USERNAME=""
MQTT_PASSWORD=""

CORS_ORIGINS=["http://localhost:3000"]
GATE_OPEN_DURATION_MS=1000
